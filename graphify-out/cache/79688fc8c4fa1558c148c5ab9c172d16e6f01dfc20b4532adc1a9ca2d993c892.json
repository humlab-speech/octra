      if (typeof error === 'object') {\n                // some other type of object\n                debug = 'OBJECT';\n                stack = JSON.stringify(error);\n              } else {\n                debug = error;\n              }\n            }\n          }\n\n          if (debug !== '') {\n            serv.addEntry(\n              ConsoleType.ERROR,\n              `${debug}${stack !== '' ? ' ' + stack : ''}`,\n            );\n          }\n\n           \n          oldError.apply(console, args);\n        };\n      })", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L661"}, {"caller_nid": "application_init_effects_applicationiniteffects_initconsolelogging", "callee": "(() => {\n        // tslint:disable-next-line:only-arrow-functions\n        console.warn = function (...args) {\n          if (args[0] && typeof args[0] === 'object' && args[0]?.type) {\n            if (isIgnoredAction(args[0].type)) {\n              return;\n            }\n          }\n\n          serv.addEntry(ConsoleType.WARN, args[0]);\n           \n          oldWarn.apply(console, args);\n        };\n      })", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L711"}, {"caller_nid": "application_init_effects_applicationiniteffects_initconsolelogging", "callee": "(() => {\n        // tslint:disable-next-line:only-arrow-functions\n        console.groupCollapsed = function (...args) {\n          serv.beginGroup(args[0]);\n           \n          oldGroupCollapsed.apply(console, args);\n        };\n      })", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L728"}, {"caller_nid": "application_init_effects_applicationiniteffects_initconsolelogging", "callee": "(() => {\n        // tslint:disable-next-line:only-arrow-functions\n        console.groupEnd = function (...args) {\n          serv.endGroup();\n           \n          oldGroupEnd.apply(console, args);\n        };\n      })", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L739"}, {"caller_nid": "application_init_effects_applicationiniteffects_getparameterbyname", "callee": "replace", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L754"}, {"caller_nid": "application_init_effects_applicationiniteffects_getparameterbyname", "callee": "exec", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L756"}, {"caller_nid": "application_init_effects_applicationiniteffects_getparameterbyname", "callee": "decodeURIComponent", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L761"}, {"caller_nid": "application_init_effects_applicationiniteffects_getparameterbyname", "callee": "replace", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L761"}, {"caller_nid": "application_init_effects_applicationiniteffects_getparameterbyname", "callee": "exec", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L767"}, {"caller_nid": "application_init_effects_applicationiniteffects_getparameterbyname", "callee": "Number", "source_file": "/Users/frkkan96/Documents/src/octra/apps/octra/src/app/core/store/application/application-init.effects.ts", "source_location": "L768"}]}