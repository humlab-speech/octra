{
  "name": "web-components",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "octra",
  "sourceRoot": "apps/web-components/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "extractLicenses": true,
        "outputPath": "tmp/web-components",
        "index": "apps/web-components/src/index.html",
        "browser": "apps/web-components/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/web-components/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "libav-default.mjs",
            "input": "apps/octra/src/assets/libav",
            "output": "assets/libav/"
          },
          {
            "glob": "libav-fat.mjs",
            "input": "apps/octra/src/assets/libav",
            "output": "assets/libav/"
          },
          {
            "glob": "libav-6.0.0-nightly.29.f420ff.ffmpeg.6.1.1-fat.wasm.mjs",
            "input": "apps/octra/src/assets/libav",
            "output": "assets/libav/"
          },
          {
            "glob": "libav-6.0.0-nightly.29.f420ff.ffmpeg.6.1.1-fat.wasm.wasm",
            "input": "apps/octra/src/assets/libav",
            "output": "assets/libav/"
          }
        ],
        "styles": ["apps/web-components/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "none"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            },
            "fonts": false
          },
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "web-components:build:production"
        },
        "development": {
          "buildTarget": "web-components:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "web-components:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web-components:build",
        "staticFilePath": "dist/apps/web-components/browser",
        "spa": true
      }
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "angular"
      }
    }
  }
}
